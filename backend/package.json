{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "lint": "oxlint .",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/lib src/services src/errors",
    "test:unit": "bun run test",
    "test:integration": "ENABLE_INTEGRATION_TEST_AUTH=true bun test src/integration",
    "test:all": "bun run test && bun run test:integration",
    "dev": "bun run --watch src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "1.4.28",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "minio": "^8.0.7",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.32.0",
    "bun-types": "1.3.13",
    "drizzle-kit": "^0.31.10",
    "oxlint": "~1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "module": "src/index.js"
}
