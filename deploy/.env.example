# Imagen de GHCR (github.com > Packages)
IMAGE_REPO=ghcr.io/tu-usuario/trashvault
IMAGE_TAG=latest

# Puertos publicados en el host (compose)
BACKEND_PORT=3000
FRONTEND_PORT=8080

# Secrets del backend
# DB en Tailscale: usa la IP 100.x de tu tailnet (el contenedor NO alcanza la VPN del Mac/Linux host).
# Ver docker-compose.tailscale.yml o docker-compose.host.yml según tu caso.
DATABASE_URL=postgresql://user:password@100.x.x.x:5432/database
FRONTEND_URL=https://tu-dominio.com

# Solo con docker-compose.tailscale.yml (genera en login.tailscale.com/admin/settings/keys)
# TS_AUTHKEY=tskey-auth-...

R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=trashvault

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
